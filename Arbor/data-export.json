      "function": "string (Residential Unit|Office Suite|Retail Store|etc.)",
      "floorArea": "number (m²)",
      "floor": "number",
      "tenant": "string (optional, only if occupied)",
      "occupancyStatus": "string (occupied|vacant|common-area)",
      "leaseStartDate": "string (optional, MMM YYYY)",
      "leaseEndDate": "string (optional, MMM YYYY)",
      "createdAt": "string (MMM YYYY)",
      "updatedAt": "string (MMM YYYY)"
    },
    "Meter": {
      "id": "string (meter-1, meter-2, etc.)",
      "name": "string",
      "type": "meter",
      "parentId": "string (references Building or Space id)",
